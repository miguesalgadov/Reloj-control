{
  "name": "reloj-control",
  "version": "0.1.0",
  "description": "Plataforma SaaS de reloj control de asistencia para Chile (Res. Ex. 38/2024 DT)",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "db:migrate": "node-pg-migrate up -m db/migrations --database-url-var MIGRATION_DATABASE_URL",
    "db:migrate:down": "node-pg-migrate down -m db/migrations --database-url-var MIGRATION_DATABASE_URL",
    "db:migrate:create": "node-pg-migrate create -m db/migrations -j sql",
    "test": "jest --config jest.unit.json",
    "test:cov": "jest --config jest.unit.json --coverage",
    "test:e2e": "jest --config test/jest-e2e.json --runInBand --forceExit"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "argon2": "^0.31.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "exceljs": "^4.4.0",
    "joi": "^17.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/pg": "^8.0.0",
    "@types/supertest": "^2.0.16",
    "dotenv": "^16.0.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.0.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "tslib": "^2.0.0",
    "typescript": "~5.1.0"
  }
}
