# =============================================================================
# Conexiones a la base de datos
#
# IMPORTANTE: hay TRES conexiones con propósito distinto.
#   - MIGRATION_DATABASE_URL: rol con privilegios para crear/alterar objetos.
#     Las tablas quedan owned por este rol. NUNCA lo usa el código de negocio.
#   - DATABASE_URL: rol de la aplicación. RLS SIEMPRE aplica. Es el que usa
#     NestJS en runtime.
#   - NEONDB_OWNER_URL (opcional, solo Neon): conexión privilegiada de
#     neondb_owner para operaciones que requieren ownership de extensiones.
#     Ver docs/operaciones-bd.md. NUNCA en código de aplicación ni en CI.
# =============================================================================

# Conexion de migraciones (superuser en local; en prod, un rol con CREATE)
MIGRATION_DATABASE_URL=postgres://postgres:postgres@localhost:5432/reloj_control

# Conexion de la aplicacion. app_login es miembro de app_user (ver bootstrap).
# El interceptor de NestJS hace SET LOCAL ROLE app_user + SET LOCAL app.tenant_id.
DATABASE_URL=postgres://app_login:cambiar_esta_clave@localhost:5432/reloj_control

# Conexion privilegiada para scripts de upgrade manual (solo Neon / cloud).
# Obtener desde el panel de Neon → Connection Details → neondb_owner.
# Guardar en .env local; NUNCA commitear ni compartir.
# NEONDB_OWNER_URL=postgres://neondb_owner:CLAVE@host.neon.tech/neondb?sslmode=require

# Nombre de la base (usado por el Makefile)
DB_NAME=reloj_control
DB_HOST=localhost
DB_PORT=5432
DB_SUPERUSER=postgres

# =============================================================================
# API NestJS
# =============================================================================

PORT=3000
NODE_ENV=development

# Secreto de firma JWT. Minimo 32 chars. Generar con: openssl rand -hex 32
JWT_SECRET=cambiar_este_secreto_minimo_32_caracteres_aqui
JWT_EXPIRES_IN=8h

# =============================================================================
# Frontend (CORS)
# =============================================================================

# URL del frontend en desarrollo. En producción, la URL real del dominio.
FRONTEND_URL=http://localhost:3001
